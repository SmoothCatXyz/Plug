{
  "name": "plug",
  "version": "0.0.0",
  "description": "Plug desktop AI workspace",
  "author": "Plug",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "dist:mac": "electron-builder --mac --arm64 --publish never",
    "dist:win": "electron-builder --win --x64 --publish never",
    "release:version": "node scripts/release-version.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@milkdown/crepe": "^7.21.1",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.191",
    "electron-updater": "^6.6.8",
    "esbuild-wasm": "^0.28.0",
    "proxy-agent": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "undici": "^8.3.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
